{
  "_generated": "DO NOT EDIT - Generated by render.py",
  "app_code": "{{ terraform_tags.app_code }}",
  "service_phase": "{{ terraform_tags.service_phase }}",
  "cost_center": "{{ terraform_tags.cost_center }}",
  "environment": "{{ environment }}",
  "account_id": "{{ account_id }}",
  "region": "{{ aws_region }}",
  "regional_id": "{% if eph_prefix %}{{ eph_prefix }}-regional{% else %}regional{% endif %}",
  "eph_prefix": "{{ eph_prefix | default('') }}",
  "enable_pagerduty": {{ observability.pagerduty.enabled | default(false) | tojson }},
  "pagerduty_escalation_policy_id": {{ observability.pagerduty.escalation_policy_id | default('') | tojson }},
  "enable_sns_alerting": {{ observability.sns_alerting.enabled | default(false) | tojson }},
  "enable_bastion": {{ rhobs_cluster.enable_bastion | default(false) | tojson }},
  "rc_state_bucket": "terraform-state-{{ account_id }}-{{ aws_region }}",
  "rc_state_key": "regional-cluster/{% if eph_prefix %}{{ eph_prefix }}-regional{% else %}regional{% endif %}.tfstate"{% if delete %},
  "delete": true{% endif %}
}
